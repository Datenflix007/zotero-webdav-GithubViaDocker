{
  "manifest_version": 2,
  "name": "MyLiteratureVault",
  "version": "0.1.6",
  "description": "Shows the MyLiteratureVault sync UI inside Zotero.",
  "author": "Datenflix007",
  "homepage_url": "https://github.com/Datenflix007/MyLiteratureVault",
  "applications": {
    "zotero": {
      "id": "myliteraturevault@datenflix007.github",
